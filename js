<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <title>Hola en JS</title>
</head>
<body>
  <h1 id="mensaje"></h1>

  <script>
    // Mostrar en consola
    console.log("¡Hola Mundo!");

    // Mostrar en la página
    document.getElementById("mensaje").innerText = "¡Hola Mundo desde JavaScript!";
  </script>
</body>
</html>
